# Each package has its own .env.local file.
# Copy the .env.example in each package and rename to .env.local:
#
#   cp packages/api/.env.example packages/api/.env.local
#   cp packages/web/.env.example packages/web/.env.local
#
# See packages/api/.env.example  — backend (Express, MongoDB, Telegram, Anthropic)
# See packages/web/.env.example  — frontend (Firebase, Vite)
