   */
  (async () => {
    const views = ['dashboard', 'log-usage', 'seats', 'schedule', 'teams', 'alerts', 'admin', 'modal'];
    await Promise.all(views.map(async (v) => {
      try {
        const res = await fetch('/views/view-' + v + '.html');
        const html = await res.text();
        document.getElementById('view-' + v).innerHTML = html;
      } catch (e) {
        console.warn('Failed to load view partial:', v, e);
      }
    }));

    // Load Alpine after DOM is fully populated
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js';
    document.head.appendChild(script);
  })();
