{
  "name": "@repo/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file .env.local src/index.ts",
    "build": "tsx build.ts --env=.env",
    "build:staging": "tsx build.ts --env=.env.staging",
    "start": "node dist/index.js",
    "start:staging": "node dist/index.js",
    "db:reset": "tsx --env-file .env.local src/scripts/db-reset.ts"
  },
  "dependencies": {
    "@repo/shared": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "firebase-admin": "^13.7.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.1",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1",
    "@types/cors": "^2",
    "@types/express": "^5",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^20",
    "@types/node-cron": "^3",
    "esbuild": "^0.25.12",
    "tsx": "^4.19.0",
    "typescript": "^5"
  }
}
