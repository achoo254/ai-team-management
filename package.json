{
  "name": "quan-ly-team-claude",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm -F @repo/web dev",
    "dev:api": "pnpm -F @repo/api dev",
    "build": "pnpm -r build",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tanstack/react-query": "^5.95.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.37",
    "eslint": "^9",
    "jsdom": "^29.0.1",
    "mongoose": "^9.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
