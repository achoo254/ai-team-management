{
  "name": "quan-ly-team-claude",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm -F @repo/web dev",
    "dev:api": "pnpm -F @repo/api dev",
    "build": "pnpm -r build",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:reset": "pnpm -F @repo/api db:reset"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "eslint": "^9",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
